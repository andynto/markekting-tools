const brandData={
  "金御賞集團":{tag:"日式餐飲品牌集團",style:"兼具職人精神、顧客體驗與多品牌經營視角",color:[24,30,43]},
  "金子半之助":{tag:"江戶前天丼專門店",style:"強調江戶前文化、現炸天婦羅、香氣與酥脆口感，保留江戶前料理文化並擴大客群",color:[111,32,22]},
  "辻半":{tag:"海鮮丼飯專門店",style:"強調海味層次、豐盛視覺、儀式感與日式丼飯體驗",color:[18,55,78]},
  "宇奈鰻魚飯":{tag:"日式鰻魚飯專門店",style:"強調炭火香氣、秘傳醬汁、現烤鰻魚、職人手藝與日式鰻魚飯文化，讓顧客感受外酥內嫩與醬香層次",color:[77,35,24]}
};
const templates={
  hook:{"新品上市":"終於等到了，這次想讓你用一餐記住新的味道。","季節限定":"季節最迷人的地方，就是錯過就要再等一年。","週年慶":"謝謝每一次走進店裡的你，讓我們有機會把一碗飯做到更好。","會員活動":"真正懂吃的熟客，值得被好好款待。","節慶檔期":"把節日過得有儀式感，從一頓好好吃飯開始。","商場導流":"逛街途中，也需要一個讓人願意停下來的理由。","媒體邀約":"一個品牌能被記住，往往從一道有故事的料理開始。","品牌故事":"好的餐飲不只是好吃，而是讓人願意再回來。","顧客回訪":"回訪不是優惠堆出來的，是體驗讓人想再來一次。"},
  cta:{"提升來客數":"現在就安排一餐，把這份限定美味排進你的行程。","提高客單價":"推薦搭配套餐與加點品項，讓這一餐更完整。","新品試吃與曝光":"歡迎來店品嚐，也分享給身邊喜歡日式料理的朋友。","會員回訪":"會員限定內容，記得出示會員資格享受專屬禮遇。","媒體報導":"歡迎媒體朋友與美食創作者預約採訪與拍攝。","社群互動":"留言告訴我們，你最想和誰一起來吃這一餐？"}
};
function $(id){return document.getElementById(id)}
function v(id){return $(id).value.trim()}
function payload(){return {brand:v('brand'),theme:v('theme'),audience:v('audience'),tone:v('tone'),goal:v('goal'),brief:v('brief')||'請輸入活動內容，例如新品、優惠、活動期間、推薦客群與主打賣點。',keywords:v('keywords')||'日式料理、職人精神、季節限定、顧客體驗',period:v('period')||'未設定',location:v('location')||'未設定',brandProfile:brandData[v('brand')]}}
function setStatus(msg,isError=false){$('status').textContent=msg;$('status').style.color=isError?'#ffb4a6':'#c8bda8'}
function setOutputs(data){$('social').textContent=data.social||'';$('press').textContent=data.press||'';$('line').textContent=data.line||'';$('video').textContent=data.video||'';$('image').textContent=data.imagePrompt||'';$('calendar').textContent=data.calendar||'';drawPoster()}
async function generateWithAI(){
  setStatus('正在呼叫 ChatGPT API 產生內容，請稍候...');$('generateBtn').disabled=true;
  try{
    const res=await fetch('/api/generate',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload())});
    const data=await res.json();
    if(!res.ok) throw new Error(data.error||'API 呼叫失敗');
    setOutputs(data);setStatus('已完成 ChatGPT API 內容產出。');
  }catch(err){setStatus('API 尚未連線或發生錯誤：'+err.message+'。可先使用「本機規則產生備案」。',true)}
  finally{$('generateBtn').disabled=false}
}
async function generateAiImage(){
  setStatus('正在呼叫圖片 API 產生主視覺，可能需要 20-60 秒...');
  try{
    const currentPrompt=$('image').textContent || localImagePrompt();
    const res=await fetch('/api/image',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({...payload(),imagePrompt:currentPrompt})});
    const data=await res.json();
    if(!res.ok) throw new Error(data.error||'圖片 API 呼叫失敗');
    $('apiImage').src=data.imageUrl || `data:image/png;base64,${data.b64}`;
    $('apiImageBox').classList.remove('hidden');
    setStatus('已完成 API 圖片產生。');
  }catch(err){setStatus('圖片 API 尚未連線或發生錯誤：'+err.message+'。可先使用本機海報。',true)}
}
function generateLocalFallback(){const p=payload(),b=p.brandProfile;setOutputs({social:localSocial(p,b),press:localPress(p,b),line:localLine(p),video:localVideo(p),imagePrompt:localImagePrompt(p,b),calendar:localCalendar(p)});setStatus('已用本機規則產生內容；此模式不會產生 API 成本。')}
function localSocial(p,b){return `【Facebook 長文】\n${templates.hook[p.theme]}\n\n${p.brand}這次以「${p.theme}」為主題，為${p.audience}設計一份更容易靠近、也更有記憶點的餐飲體驗。\n\n活動重點：\n${p.brief}\n\n我們想傳遞的不是單純促銷，而是${b.style}。\n活動期間：${p.period}\n活動地點：${p.location}\n\n關鍵亮點：${p.keywords}\n\n${templates.cta[p.goal]}\n\n#${p.brand} #金御賞 #${p.theme} #日式料理 #餐飲體驗\n\n---\n【Instagram 貼文】\n${templates.hook[p.theme]}\n\n一份好吃的料理，應該同時有香氣、口感、畫面與故事。\n\n${p.brand}｜${b.tag}\n${p.brief}\n\n推薦給：${p.audience}\n風格：${p.tone}\n重點：${p.keywords}\n\n收藏這篇，下次想吃日式料理時就不會忘記。\n\n---\n【Threads 短文】\n${templates.hook[p.theme]}\n${p.brand}這次的${p.theme}，不是只想做優惠，而是想讓你多一個「今天就想吃日式料理」的理由。\n\n${templates.cta[p.goal]}`}
function localPress(p,b){return `新聞稿標題：\n${p.brand}推出「${p.theme}」企劃，以${b.tag}打造日式餐飲新體驗\n\n新聞稿前言：\n金御賞旗下品牌${p.brand}宣布推出「${p.theme}」行銷企劃，鎖定${p.audience}，透過${b.style}，強化品牌與消費者之間的連結，並以「${p.goal}」作為本次活動核心目標。\n\n活動內容：\n${p.brief}\n\n活動期間：${p.period}\n活動地點：${p.location}\n\n品牌觀點：\n${p.brand}表示，餐飲品牌的競爭不只是產品本身，更包含顧客進店前的期待、用餐中的體驗，以及離店後願不願意再次回訪。本次企劃將以${p.keywords}作為溝通主軸，希望讓更多消費者感受到日式料理的細節與溫度。\n\n媒體聯絡資訊：\n金御賞公司 行銷部 / 公關窗口`}
function localLine(p){return `【LINE OA 推播】\n${p.brand} ${p.theme}登場！\n${p.brief}\n\n活動期間：${p.period}\n適合${p.audience}，現在就安排一餐。\n\n---\n【簡訊版】\n${p.brand}${p.theme}活動開跑：${p.brief.slice(0,62)}... 詳情請洽門市或官方社群。`}
function localVideo(p){return `【15秒短影音腳本】\n0-3秒｜料理特寫 / 現場製作 / 熱氣與香氣\n字幕：${templates.hook[p.theme]}\n\n4-8秒｜主餐、套餐、顧客用餐反應\n旁白：${p.brand}這次為${p.audience}準備了新的${p.theme}企劃。\n\n9-12秒｜活動重點快速切換\n字幕：${p.brief}\n\n13-15秒｜品牌 LOGO + 門市 / 訂位資訊\n字幕：現在就來店體驗。`}
function localImagePrompt(p=payload(),b=p.brandProfile){return `請生成一張適合${p.brand}「${p.theme}」活動的日式餐飲社群主視覺。\n風格：${p.tone}、乾淨高質感、日式留白、暖色燈光、料理特寫、細緻餐具、品牌感明確。\n品牌調性：${b.style}。\n畫面元素：主餐料理、日式木質桌面、柔和景深、自然光、可放置活動標題的留白區。\n關鍵字：${p.keywords}。\n尺寸：1:1 Instagram 貼文。\n避免：過度卡通、廉價促銷感、雜亂背景、錯誤日文字、過多文字。`}
function localCalendar(p){return `【7天行銷排程】\nD-7：預告貼文，建立期待感\nD-5：料理細節與製程短影音\nD-3：LINE OA 推播 / 會員提醒\nD-1：倒數貼文 + 門市資訊\nD-Day：主視覺貼文 + Reels 上線\nD+3：顧客回饋 / UGC 分享\nD+7：成效回顧 + 下一波導流`}
function showTab(e,id){document.querySelectorAll('.panelText').forEach(x=>x.classList.add('hidden'));document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));$(id).classList.remove('hidden');e.target.classList.add('active')}
function allText(){return ['social','press','line','video','image','calendar'].map(id=>$(id).textContent).join('\n\n====================\n\n')}
function copyAll(){navigator.clipboard.writeText(allText());setStatus('已複製全部內容。')}
function downloadText(){const blob=new Blob([allText()],{type:'text/plain;charset=utf-8'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='金御賞AI行銷內容.txt';a.click()}
function wrapText(ctx,text,x,y,maxWidth,lineHeight){const chars=String(text).split('');let line='';for(let n=0;n<chars.length;n++){const test=line+chars[n];if(ctx.measureText(test).width>maxWidth&&n>0){ctx.fillText(line,x,y);line=chars[n];y+=lineHeight}else line=test}ctx.fillText(line,x,y);return y}
function drawPoster(){const p=payload(),c=$('poster'),ctx=c.getContext('2d'),b=p.brandProfile;const [r,g,bl]=b.color;ctx.fillStyle=`rgb(${r},${g},${bl})`;ctx.fillRect(0,0,1080,1080);let grd=ctx.createLinearGradient(0,0,1080,1080);grd.addColorStop(0,'rgba(244,217,153,.9)');grd.addColorStop(.38,'rgba(255,255,255,.08)');grd.addColorStop(1,'rgba(0,0,0,.25)');ctx.fillStyle=grd;ctx.fillRect(0,0,1080,1080);ctx.fillStyle='rgba(255,255,255,.1)';for(let i=0;i<8;i++){ctx.beginPath();ctx.arc(120+i*140,180+i%2*120,70,0,Math.PI*2);ctx.fill()}ctx.fillStyle='#fff7e8';ctx.font='bold 58px sans-serif';ctx.fillText(p.brand,80,140);ctx.font='900 92px sans-serif';wrapText(ctx,p.theme,80,330,860,105);ctx.font='32px sans-serif';ctx.fillStyle='#f4d999';wrapText(ctx,b.tag,80,530,860,44);ctx.fillStyle='rgba(0,0,0,.28)';ctx.fillRect(80,650,920,260);ctx.fillStyle='#fff';ctx.font='38px sans-serif';wrapText(ctx,p.brief.slice(0,70),120,730,830,58);ctx.font='bold 34px sans-serif';ctx.fillStyle='#f4d999';ctx.fillText('立即來店體驗',120,945);ctx.font='24px sans-serif';ctx.fillStyle='rgba(255,255,255,.75)';ctx.fillText('Kingoshou AI Marketing Visual Draft',120,990)}
function downloadPoster(){const a=document.createElement('a');a.href=$('poster').toDataURL('image/png');a.download='金御賞行銷視覺稿.png';a.click()}
async function downloadApiImage(){if(!$('apiImage').src){setStatus('目前沒有 API 圖片可下載。',true);return}const a=document.createElement('a');a.href=$('apiImage').src;a.download='金御賞AI圖片.png';a.click()}
let deferredPrompt;window.addEventListener('beforeinstallprompt',e=>{e.preventDefault();deferredPrompt=e;$('installBtn').classList.remove('hidden')});$('installBtn').addEventListener('click',async()=>{if(deferredPrompt){deferredPrompt.prompt();deferredPrompt=null}});if('serviceWorker'in navigator){navigator.serviceWorker.register('service-worker.js')}
generateLocalFallback();
